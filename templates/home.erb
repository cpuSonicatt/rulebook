<!DOCTYPE html>
<html lang="en">
    <head>
        <title>Jack's Rule Book</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta charset="UTF-8">

        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📜</text></svg>">
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300..800" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Noto+Color+Emoji&amp;display=swap" rel="stylesheet">
        <link href="./assets/bootstrap.min.css" rel="stylesheet">
        <link href="./style.css" rel="stylesheet">
    </head>

    <body class="bg-dark container my-5">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <pattern id="bg" patternUnits="userSpaceOnUse" patternContentUnits="userSpaceOnUse" width="40" height="40">
                    <g fill="var(--accent-dark)" fill-opacity='0.4' fill-rule='evenodd'><path d='M0 40L40 0H20L0 20M40 40V20L20 40'/></g>
                </pattern>
            </defs>
            <rect fill="url(#bg)" width="100%" height="100%"></rect>
        </svg>

        <div class="bg-light py-4 shaadow">
            <div class="d-flex flex-row justify-content-center align-items-center">
                <div class="icon">📜</div>
                <h1 class="m-4 text-start fw-light">Jack's<br><b>Rule Book</b></h1>
            </div>
<% categories.each do |id,pretty| %>
            <div class="m-5">
                <p class="hr"><span><%= pretty %></span></p>
                <div class="row">
<% games.select { |g| g["category"] == id }.sort_by { |e| e["id"]}.each do |game| %>
                    <div class="col-xxl-4 col-lg-6 col-sm-12">
                        <a class="a-reg-colour" href="./games/<%= game["id"] %>">
                            <div class="d-flex flex-sm-row flex-column align-items-center text-center text-sm-start my-4">
                                <div class="icon"><%= game["icon"] %></div>
                                <div class="mx-4">
                                    <div class="fs-4 hover"><b><%= game["name"] %></b></div>
                                    <%= game["subtext"] %>
                                </div>
                            </div>
                        </a>
                    </div>
<% end %>
                </div>
            </div>
<% end %>
            <hr class="mx-4">
            <div class="text-center fs-5">
                <p>
                    <a href="https://getbootstrap.com/">Bootstrap v5</a> • <a href="https://fonts.google.com/specimen/Manrope">Manrope</a> • <a href="https://fonts.google.com/noto/specimen/Noto+Color+Emoji">Noto Color Emoji</a>
                </p>
                <div id="madewith" class="nolig text-center">
                    <span>Made with</span>
                    <span id="madewithp" class="r"></span>
                    <span>by Jack</span>
                </div>
            </div>
        </div>
    </body>
</html>

<style>
svg {
    position: fixed;
    inset: 0;
    z-index: -1;
}
</style>


