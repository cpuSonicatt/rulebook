<!DOCTYPE html>
<html lang="en">
    <head>
        <title>Jack's Rule Book</title>
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta charset="UTF-8">

        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📜</text></svg>">
        <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300..800" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-GLhlTQ8iRABdZLl6O3oVMWSktQOp6b7In1Zl3/Jr59b6EGGoI1aFkw7cmDA6j6gD" crossorigin="anonymous">
        <link href="./style.css" rel="stylesheet">

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js" integrity="sha384-w76AqPfDkMBDXo30jS1Sgez6pr3x5MlQ1ZAGC+nuZB+EYdgRZgiwxhTBTkF7CXvN" crossorigin="anonymous"></script>
    </head>

    <body class="bg-dark container my-5">
        <div class="bg-light p-4 px-5 shaadow">
            <div class="d-flex flex-sm-row flex-column justify-content-center align-items-center">
                <div class="icon">📜</div>
                <h1 class="m-4 text-start fw-light">Jack's<br><b>Rule Book</b></h1>
            </div>
<% categories.each do |id,pretty| %>
            <div class="my-4">
                <p class="hr"><span><%= pretty %></span></p>
                <div class="row">
<% games.select { |g| g["category"] == id }.sort_by { |e| e["id"]}.each do |game| %>
                    <div class="col-xxl-4 col-lg-6 col-sm-12">
                        <a class="a-reg-colour" href="./games/<%= game["id"] %>">
                            <div class="d-flex flex-sm-row flex-column align-items-center text-center text-sm-start my-4">
                                <div class="icon"><%= game["icon"] %></div>
                                <div class="mx-1">
                                    <div id="hover" class="fs-4"><b><%= game["name"] %></b></div>
                                    <%= [game["type"], game["players"] + " player" + (game["players"] == "1" ? "" : "s")].join(" • ") %>
                                </div>
                            </div>
                        </a>
                    </div>
<% end %>
                </div>
            </div>
<% end %>
            <hr>
            <div class="text-center mt-5 fs-5">
                <p class="fs-5">
                    <a href="https://getbootstrap.com/">Bootstrap v5</a> • <a href="https://fonts.google.com/specimen/Manrope">Manrope</a>
                </p>
                <p class="nolig">
                    Made with <span id="madewithp" class="r"></span> by Jack
                </p>
            </div>
        </div>
    </body>

